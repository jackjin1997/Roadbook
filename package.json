{
  "name": "roadbook",
  "private": true,
  "version": "0.7.0",
  "description": "输入一份 JD，Ariadne 为你生成专属的通关路书",
  "type": "module",
  "packageManager": "pnpm@10.29.1",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"vite\" \"tsx watch src/ariadne/server.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx watch src/ariadne/server.ts",
    "build": "tsc --project tsconfig.json --noEmit && tsc --project tsconfig.ariadne.json --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "ariadne": "tsx src/ariadne/cli.ts",
    "ariadne:server": "tsx src/ariadne/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:eval": "vitest run --config vitest.eval.config.ts",
    "eval:langsmith": "tsx src/ariadne/__tests__/eval/langsmith-eval.ts",
    "eval:langsmith:ci": "tsx src/ariadne/__tests__/eval/langsmith-eval.ts --ci"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.22",
    "@langchain/core": "^1.1.31",
    "@langchain/google-genai": "^2.1.24",
    "@langchain/langgraph": "^1.2.0",
    "@langchain/openai": "^1.2.12",
    "@langchain/tavily": "^1.2.0",
    "@mozilla/readability": "^0.6.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tauri-apps/api": "^2.10.1",
    "@types/jsdom": "^28.0.0",
    "@types/multer": "^2.1.0",
    "@types/pdf-parse": "^1.1.5",
    "cors": "^2.8.6",
    "d3": "^7.9.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsdom": "^28.1.0",
    "jszip": "^3.10.1",
    "langchain": "^1.2.30",
    "langsmith": "^0.5.7",
    "mammoth": "^1.11.0",
    "mermaid": "^11.12.3",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/cors": "^2.8.19",
    "@types/d3": "^7.4.3",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.2.1",
    "openevals": "^0.1.4",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
